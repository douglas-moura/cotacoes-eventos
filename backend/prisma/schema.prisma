generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
    id          Int         @id @default(autoincrement())
    nome        String      @map("name")
    email       String      @unique
    senha       String
    data_nasc   DateTime?
    createdAt   DateTime    @default(now())
    ativo       Boolean     @default(true) @map("isActive")

    acessos Acessos[]

    @@map("users")
}

model Acessos {
    id              Int         @id @default(autoincrement())
    user_id         Int
    dispositivo     String
    data_login      DateTime

    fk_usuario User @relation(fields: [user_id], references: [id])

    @@map("acessos")
}