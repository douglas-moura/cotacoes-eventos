// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
    id                                  Int                 @id @default(autoincrement())
    nome                                String              @map("name")
    email                               String              @unique
    senha                               String
    data_nasc                           DateTime?
    createdAt                           DateTime            @default(now())
    ativo                               Boolean             @default(true) @map("isActive")

    acessos                             Acessos[]
    espacos                             Espaco[]
    enderecos                           Endereco[]

    @@map("users")
}

model Acessos {
    id                                  Int                 @id @default(autoincrement())

    user_id                             Int
    fk_usuario                          User                @relation(fields: [user_id], references: [id])
    
    dispositivo                         String
    data_login                          DateTime            @default(now())

    @@map("acessos")
}

model Espaco {
    id                                  Int                 @id @default(autoincrement())
    nome                                String
    descricao                           String    

    proprietario_id                     Int                 // chave estrangeira para a tabela User
    fk_proprietario                     User                @relation(fields: [proprietario_id], references: [id])

    area                                Float?
    capacidade                          Int?
    ambientes                           Int?
    quantidadeBanheiros                 Int?

    ativo                               Boolean             @default(true)
    visivel                             Boolean             @default(true)

    endereco                            Endereco?           // este campo não cria coluna, apenas faz ref a tabela Endereco onde há uma chave estrangeira apontada para cá
    infraestruturas                     EspacoInfra[]
    servicos                            Servico[]

    @@map("espacos")
}

model Endereco {
    id                                  Int                 @id @default(autoincrement())
    rua                                 String
    numero                              String
    complemento                         String?
    referencia                          String?
    bairro                              String
    cidade                              String
    uf                                  String              @db.Char(2)
    cep                                 String

    espaco_id                           Int                 @unique // isto indica para o Prisma que o id do espaco não pode ser repetir aqui (1 para 1)
    fk_espaco                           Espaco              @relation(fields: [espaco_id], references: [id])
    user_id                             Int        
    fk_user                             User                @relation(fields: [user_id], references: [id])

    @@map("enderecos")
}

model Infraestrutura {
    id                                  Int                 @id @default(autoincrement())
    titulo                              String              @unique
    icone                               String?

    espacos                             EspacoInfra[]
    
    @@map("infraestruturas")
}

model EspacoInfra {
    id                                  Int                 @id @default(autoincrement())
    
    espaco_id                           Int
    fk_espaco                           Espaco              @relation(fields: [espaco_id], references: [id])
    
    infra_id                            Int
    fk_infra                            Infraestrutura      @relation(fields: [infra_id], references: [id])

    @@unique([espaco_id, infra_id])

    @@map("rel_espacos_infras")
}

model Servico {
    id                                  Int                 @id @default(autoincrement())

    tipo                                String

    valor_base                          Int

    valor_promo                         Int?
    valor_promo_status                  Boolean             @default(false)

    tx_pessoa                           Int?
    tx_pessoa_status                    Boolean             @default(false)

    diaria                              Diaria?
    alimentacao                         Alimentacao?
    bebida                              Bebida?

    espaco_id                           Int?
    fk_espaco                           Espaco?             @relation(fields: [espaco_id], references: [id])
    
    @@map("servicos")
}

model Diaria {
    id                                  Int                 @id @default(autoincrement())

    dia_semana                          String?

    check_in                            String              @default("00h00")
    check_out                           String              @default("00h00")

    ativo                               Boolean             @default(true)

    servico_id                          Int                 @unique
    fk_servico                          Servico             @relation(fields: [servico_id], references: [id])

    @@map("serv_diarias")
}

model Alimentacao {
    id                                  Int                 @id @default(autoincrement())

    servico_id                          Int                 @unique
    servico                             Servico             @relation(fields: [servico_id], references: [id])

    @@map("serv_alimentacao")
}

model Bebida {
    id                                  Int                 @id @default(autoincrement())

    servico_id                          Int                 @unique
    servico                             Servico             @relation(fields: [servico_id], references: [id])
    
    @@map("serv_bebidas")
}